<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="trip_manager_itineary_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.itineary.view.tree</field>
        <field name="model">trip.manager.itineary</field>
        <field name="arch" type="xml">
            <list>
                <field name="package_id"/>
                <field name="no_of_days"/>
                <field name="day_number"/>
                <field name="description" widget="html"/>
                <field name="hotel_id"/>
                <field name="destination_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_itineary" model="ir.actions.act_window"> 
        <field name="name">Itineariess</field>
        <field name="res_model">trip.manager.itineary</field>
        <field name="view_mode">list</field>
    </record>
</odoo>