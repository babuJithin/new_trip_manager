<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="trip_manager_city_view_form" model="ir.ui.view">
        <field name="name">trip.manager.city.view.form</field>
        <field name="model">trip.manager.city</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state_id"
                                placeholder="State"
                                class="o_address_state"
                                options="{'no_open': True, 'no_quick_create': True}"
                                context="{'default_country_id': country_id}"/>
                        <field name="country_id"
                                placeholder="Country"
                                class="o_address_country"
                                options="{'no_open': True, 'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="trip_manager_city_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.city.view.tree</field>
        <field name="model">trip.manager.city</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state_id"
                        placeholder="State"
                        class="o_address_state"
                        options="{'no_open': True, 'no_quick_create': True}"
                        context="{'default_country_id': country_id}"/>
                <field name="country_id"
                        placeholder="Country"
                        class="o_address_country"
                        options="{'no_open': True, 'no_create': True}"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_city" model="ir.actions.act_window"> 
        <field name="name">Cities</field>
        <field name="res_model">trip.manager.city</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>