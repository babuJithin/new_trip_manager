<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="trip_manager_destination_view_form" model="ir.ui.view">
        <field name="name">trip.manager.destination.view.form</field>
        <field name="model">trip.manager.destination</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'size': [320, 320]}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Destination Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Info">
                            <field name="destination_category_ids" widget="many2many_tags"/>
                            <field name="city_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Entry">
                            <field name="has_entry_ticket"/>
                            <field name="entry_ticket_price"
                                invisible="not has_entry_ticket"
                                readonly="not has_entry_ticket"/>
                        </group>
                    </group>
                    <group string="Visiting Hours">
                        <group>
                            <field name="availability_type"/>

                            <field name="start_time"
                                invisible="availability_type != 'timed'"
                                widget="float_time" string="Opens At"/>

                            <field name="end_time"
                                invisible="availability_type != 'timed'"
                                widget="float_time" string="Closes At"/>

                            <field name="has_second_slot"
                                invisible="availability_type != 'timed'"/>

                            <field name="slot2_start_time"
                                invisible="not has_second_slot or availability_type != 'timed'"
                                widget="float_time" string="Reopens At"/>

                            <field name="slot2_end_time"
                                invisible="not has_second_slot or availability_type != 'timed'"
                                widget="float_time" string="Closes Again At"/>
                        </group>
                        <group>
                            <field name="visiting_hours_display"
                                invisible="availability_type != 'timed'"
                                readonly="1" string="Timings"/>
                        </group>
                    </group>

                    <group string="Related">
                        <group>
                            <field name="hotel_ids"
                                widget="many2many_tags"
                                domain="[('city_ids', 'in', city_ids)]"/>
                        </group>
                        <group>
                            <field name="activity_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="trip_manager_destination_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.destination.view.tree</field>
        <field name="model">trip.manager.destination</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="city_ids" widget="many2many_tags"/>
                <field name="destination_category_ids" widget="many2many_tags"/>
                <field name="start_time"/>
                <field name="end_time"/>
            </list>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="trip_manager_destination_view_kanban" model="ir.ui.view">
        <field name="name">trip.manager.destination.view.kanban</field>
        <field name="model">trip.manager.destination</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="image"/>
                <field name="city_ids"/>
                <field name="destination_category_ids"/>
                <field name="availability_type"/>
                <field name="visiting_hours_display"/>
                <templates>
                    <t t-name="card">
                    
                        <!-- Image -->
                        <div class="o_kanban_image">
                            <img t-if="record.image.value"
                                t-att-src="'/web/image/trip.manager.destination/' + record.id.value + '/image'"
                                alt="Destination"
                                style="width:100%; height:160px; object-fit:cover; border-radius:6px 6px 0 0;"/>
                            <div t-else=""
                                style="width:100%; height:160px; background:#e9ecef; border-radius:6px 6px 0 0; display:flex; align-items:center; justify-content:center; color:#adb5bd; font-size:13px;">
                                No Image
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="p-2">

                            <!-- Name -->
                            <h5 class="fw-bold mb-1">
                                <field name="name"/>
                            </h5>

                            <!-- Location Type tags -->
                            <div class="mb-1">
                                <field name="destination_category_ids" widget="many2many_tags"/>
                            </div>

                            <!-- Cities -->
                            <div class="d-flex align-items-center gap-1 text-muted small mb-1">
                                <i class="fa fa-map-marker me-1" title="Location"/>
                                <field name="city_ids" widget="many2many_tags"/>
                            </div>

                            <!-- Timing -->
                            <div class="d-flex align-items-center text-muted small">
                                <i class="fa fa-clock-o me-1" title="Visiting Hours"/>
                                <field name="timing_display"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_destination" model="ir.actions.act_window"> 
        <field name="name">Destinations</field>
        <field name="res_model">trip.manager.destination</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>