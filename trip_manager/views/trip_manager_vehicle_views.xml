<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="trip_manager_vehicle_view_form" model="ir.ui.view">
        <field name="name">trip.manager.vehicle.view.form</field>
        <field name="model">trip.manager.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Transport Name"/>
                        </h1>
                        <field name="active" widget="boolean_toggle"/>
                    </div>
                    <group>
                        <group string="General">
                            <field name="owner_id"/>
                        </group>

                        <group string="Pricing">
                            <field name="rent_per_day" widget="monetary"/>
                        </group>
                    </group>

                    <group string="Land Details">
                        <group>
                            <field name="vehicle_type"/>
                            <field name="vehicle_number"/>
                        </group>
                        <group>
                            <field name="included_km_per_day"/>
                            <field name="extra_km_rate"  widget="monetary"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="trip_manager_vehicle_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.vehicle.view.tree</field>
        <field name="model">trip.manager.vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_type"
                       optional="show"/>
                <field name="rent_per_day"  widget="monetary"/>
                <field name="owner_id"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_vehicle" model="ir.actions.act_window">
        <field name="name">Transport</field>
        <field name="res_model">trip.manager.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>