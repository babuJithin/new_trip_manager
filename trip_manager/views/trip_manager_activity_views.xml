<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="trip_manager_activity_view_form" model="ir.ui.view">
        <field name="name">trip.manager.activity.view.form</field>
        <field name="model">trip.manager.activity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="trip_manager_activity_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.activity.view.tree</field>
        <field name="model">trip.manager.activity</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_activity" model="ir.actions.act_window"> 
        <field name="name">Activities</field>
        <field name="res_model">trip.manager.activity</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>