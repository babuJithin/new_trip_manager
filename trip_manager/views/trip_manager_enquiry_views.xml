<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_trip_manager_enquiry_form" model="ir.ui.view">
        <field name="name">trip.manager.enquiry.form</field>
        <field name="model">trip.manager.enquiry</field>
        <field name="arch" type="xml">
            <form string="Trip Enquiry">
                <header>
                    <button name="action_set_estimate"
                            string="Set to Estimate"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_print_quotation"
                            string="Print Quotation"
                            type="object"
                            class="btn-secondary"
                            icon="fa-print"/>
                    <button name="action_confirm"
                            string="Confirm Booking"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'estimate'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-secondary"
                            invisible="state == 'draft'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,estimate,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Customer Info">
                            <field name="customer_id"/>
                            <field name="no_of_adult"/>
                            <field name="no_of_child"/>
                        </group>
                        <group string="Trip Info">
                            <field name="tour_start_date"/>
                            <field name="tour_end_date"/>
                            <field name="no_of_day" readonly="1"/>
                        </group>
                    </group>
                    <group string="Package">
                        <group>
                            <field name="destination_city_id"/>
                            <field name="package_id"/>
                        </group>
                        <group>
                            <field name="package_type" widget="radio" options="{'horizontal': True}"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Options — Standard, Deluxe, Premium, Luxury -->
                        <page string="Options" name="options">
                                <field name="option_ids" context="{
                                    'default_enquiry_id':    id,
                                    'default_package_id':    package_id,
                                    'default_tour_start_date': tour_start_date
                                }">
                                <list>
                                    <field name="package_category" string="Package Category"/>
                                    <field name="total_accomodation_cost" widget="monetary" string="Accommodation"/>
                                    <field name="total_transport_cost" widget="monetary" string="Transportation"/>
                                    <field name="total_addon_cost" widget="monetary" string="Additional"/>
                                    <field name="total_amount" widget="monetary" string="Total Amount"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="trip_manager_enquiry_view_tree" model="ir.ui.view">
        <field name="name">trip.manager.enquiry.view.tree</field>
        <field name="model">trip.manager.enquiry</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="destination_city_id" string="Destination"/>
                <field name="package_id" string="Package"/>
                <field name="tour_start_date" string="Start Date"/>
                <field name="tour_end_date" string="End Date"/>
                <field name="no_of_adult" string="Adults"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'estimate'"
                       decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_trip_manager_enquiry" model="ir.actions.act_window">
        <field name="name">Enquiries</field>
        <field name="res_model">trip.manager.enquiry</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>