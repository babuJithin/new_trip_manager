<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_trip_manager" model="ir.module.category">
            <field name="name">Trip Manager</field>
            <field name="sequence">20</field>
        </record>

        <record id="privilege_trip_manager" model="res.groups.privilege">
            <field name="name">Trip Manager</field>
            <field name="category_id" ref="module_category_trip_manager"/>
        </record>

        <record id="group_trip_manager_agent" model="res.groups">
            <field name="name">Agent</field>
            <field name="privilege_id" ref="privilege_trip_manager"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_trip_manager_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_trip_manager"/>
            <field name="implied_ids" eval="[(4, ref('group_trip_manager_agent'))]"/>
        </record>

    </data>
</odoo>